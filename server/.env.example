# Server（端口避开画师库的 3001/5174）
SERVER_HOST=0.0.0.0
SERVER_PORT=3002

# MySQL Database（本机已有 MySQL 8；库名独立于画师库）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=sourcing_radar

# 允许跨域访问的前端源（逗号分隔），不配置则使用内置开发默认值
# CORS_ORIGINS=http://localhost:5175,http://localhost:3002

# JWT（登录鉴权密钥，必填；生成：node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"）
JWT_SECRET=

# AI 助手（全库聊天 + 本周建议动作）。走 Anthropic Messages 协议的中转网关。
# 不配置 AI_API_KEY 时其它接口照常工作，仅 AI 功能不可用（启动会打印告警）。
AI_API_KEY=
# 中转网关地址，例如 https://your-gateway.example.com（留空则用 SDK 默认 Anthropic 官方地址）
AI_BASE_URL=
# 模型名，默认 deepseek-v4-pro
# AI_MODEL=deepseek-v4-pro
# 单次回复最大 token，默认 4000
# AI_MAX_TOKENS=4000
# 请求超时（毫秒），默认 90000
# AI_TIMEOUT_MS=90000
