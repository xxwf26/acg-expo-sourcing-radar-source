# Server（端口避开画师库的 3001/5174）
SERVER_HOST=0.0.0.0
SERVER_PORT=3002

# MySQL Database（本机已有 MySQL 8；库名独立于画师库）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=sourcing_radar

# 允许跨域访问的前端源（逗号分隔），不配置则使用内置开发默认值
# CORS_ORIGINS=http://localhost:5175,http://localhost:3002

# JWT（登录鉴权密钥，必填；生成：node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"）
JWT_SECRET=
